{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operator Run List",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "run_id": {
        "type": "string"
      },
      "status": {
        "type": "string"
      },
      "started_at": {
        "type": "string",
        "format": "date-time"
      }
    },
    "required": [
      "run_id",
      "status",
      "started_at"
    ]
  },
  "x-schema-version": "1.0.0",
  "required": [
    "items",
    "count",
    "total_runs"
  ]
}
