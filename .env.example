# Jarvis environment example
# Copy to .env and fill only what you use.
# Precedence:
#   process env > .env canonical JARVIS_LLM_* > provider-native fallback > deprecated legacy aliases
# Do not commit real secrets.

# -----------------------------------------------------------------------------
# LLM provider (recommended canonical form)
# -----------------------------------------------------------------------------
JARVIS_LLM_PROVIDER=deepseek
JARVIS_LLM_MODEL=deepseek-chat
JARVIS_LLM_BASE_URL=https://api.deepseek.com
JARVIS_LLM_API_KEY=your_api_key_here
JARVIS_LLM_TEMPERATURE=0.2
JARVIS_LLM_TIMEOUT_SECONDS=60
JARVIS_LLM_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Optional provider-native fallback examples
# Use these only if you prefer native provider names.
# If JARVIS_LLM_API_KEY is set, it wins.
# -----------------------------------------------------------------------------
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
#
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com
#
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api
#
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io
#
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=https://ollama.com

# -----------------------------------------------------------------------------
# Jarvis runtime
# -----------------------------------------------------------------------------
JARVIS_MODE=safe
JARVIS_API_BASE=http://127.0.0.1:8765
JARVIS_AGENT_MODEL_MODE=auto
JARVIS_AGENT_MAX_STEPS=8
JARVIS_AGENT_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# Optional web/search keys
# -----------------------------------------------------------------------------
# TAVILY_API_KEY=
# SERPER_API_KEY=
# BRAVE_API_KEY=
# EXA_API_KEY=

# -----------------------------------------------------------------------------
# Migration note
# -----------------------------------------------------------------------------
# Legacy names such as:
#   LLM_DEEPSEEK_API_KEY
#   JARVIS_LLM_DEEPSEEK_API_KEY
#   LLM_OPENAI_API_KEY
#   JARVIS_LLM_OPENAI_API_KEY
# are still read for compatibility, but deprecated.
