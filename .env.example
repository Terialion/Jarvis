# ================================================
# Generic OpenAI-compatible LLM provider (preferred)
# ================================================
# Keep real secrets in local .env only. Never commit real API keys.
JARVIS_LLM_PROVIDER=openai_compatible
JARVIS_LLM_BASE_URL=https://api.deepseek.com/v1
JARVIS_LLM_API_KEY=your_api_key_here
JARVIS_LLM_MODEL=deepseek-chat
JARVIS_LLM_TEMPERATURE=0.2
JARVIS_LLM_TIMEOUT_SECONDS=60
JARVIS_LLM_MAX_TOKENS=4096
# .env.example
# 示例环境变量（仅作示例，不要将真实密钥提交到远程仓库）

# ================================================
# J.A.R.V.I.S 核心配置
# ================================================

# 最小模式（无语音功能，快速启动）
# true:  不加载语音相关功能，不下载模型，快速启动
# false: 加载完整功能（需要下载模型）
JARVIS_MINIMAL_MODE=false

# Jarvis 运行模式
# safe:   安全模式（默认，文件操作需审批）
# debug:  调试模式（详细日志）
# silent: 静默模式（最小化输出）
JARVIS_MODE=safe

# API 服务器配置
JARVIS_API_HOST=127.0.0.1
JARVIS_API_PORT=8765

# 功能开关
JARVIS_NETWORK_ENABLED=false    # 是否启用网络访问
JARVIS_DOCKER_ENABLED=false    # 是否启用 Docker

# ================================================
# LLM 提供商配置
# ================================================

# DeepSeek API Key (必填)
DEEPSEEK_API_KEY=your_api_key_here
LLM_DEEPSEEK_API_KEY=your_api_key_here
JARVIS_LLM_DEEPSEEK_API_KEY=your_api_key_here

# OpenAI API Key (可选)
OPENAI_API_KEY=your_openai_key_here

# MiniMax API (可选)
MINIMAX_API_BASE=https://api.minimax.chat/v1
MINIMAX_API_KEY=your_minimax_key_here

# ================================================
# 语音功能配置（仅当 JARVIS_MINIMAL_MODE=false 时生效）
# ================================================

# 语音识别模型 (base/small/medium/large)
WHISPER_MODEL=base
ASR_MODEL=base

# TTS 语音 (见 README 选项)
TTS_VOICE=zh-CN-YunxiNeural
TTS_RATE=-12%
TTS_PITCH=-2Hz
TTS_BACKEND=auto

# TTS 自动切换阈值（短句 Edge-TTS，长讲解 ChatTTS）
TTS_AUTO_CHAT_MIN_CHARS=90
TTS_AUTO_CHAT_MIN_SENTENCES=3

# 最大录音时长（秒）
MAX_RECORD_SECONDS=10

# ================================================
# 联网搜索配置（可选）
# ================================================

# 推荐使用 Tavily（质量最好）
TAVILY_API_KEY=your_tavily_key_here

# 备选搜索 API
SCRAPE_DO_API_KEY=your_scrape_do_key_here
BING_SEARCH_API_KEY=your_bing_key_here
SERPER_API_KEY=your_serper_key_here

# 搜索策略
SEARCH_PREFER_API=auto          # auto: 自动选择最佳 API
SEARCH_TOTAL_BUDGET=12         # 总搜索预算（次数）

# ================================================
# Skills 配置（按需填写）
# ================================================

# QQ 邮箱（用于 `qq-email` Skill）
QQ_EMAIL_ACCOUNT=your_qq_email@example.com
QQ_EMAIL_AUTH_CODE=your_smtp_auth_code_here

# 腾讯文档（用于 `tencent-docs` Skill）
TENCENT_DOCS_APP_ID=your_tencent_docs_app_id
TENCENT_DOCS_APP_SECRET=your_tencent_docs_app_secret

# 腾讯会议（用于 `tencent-meeting-skill`）
TENCENT_MEETING_APP_ID=your_tencent_meeting_app_id
TENCENT_MEETING_SECRET=your_tencent_meeting_secret

# ================================================
# 说明
# ================================================

# 1. 将本文件复制为 .env 并填写真实值以在本地启用对应功能
# 2. 切勿将包含真实凭据的 .env 推送到公共仓库
# 3. 最小模式（JARVIS_MINIMAL_MODE=true）：
#    - 不加载语音识别和语音合成
#    - 不下载 FunASR / ChatTTS 等模型
#    - 快速启动，适合开发调试
# 4. 完整模式（JARVIS_MINIMAL_MODE=false）：
#    - 加载所有功能
#    - 首次使用会下载模型（可能需要几分钟）
#    - 支持语音交互

# ================================================
# 快速开始（最小模式）
# ================================================

# 1. 复制配置：
#    copy .env.example .env    (Windows)
#    cp .env.example .env      (Linux/macOS)
#
# 2. 编辑 .env，设置：
#    JARVIS_MINIMAL_MODE=true
#    DEEPSEEK_API_KEY=your_key
#
# 3. 安装最小依赖：
#    pip install -r requirements-minimal.txt
#
# 4. 启动 Jarvis：
#    python -m jarvis.cli
#
# 完成！无需下载任何模型，快速启动。